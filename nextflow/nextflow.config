manifest {
  name = 'team4-feature-engineering'
  mainScript = 'nextflow/main.nf'
}

params {
  aws_region = 'ap-northeast-2'
  run_id = null
  out_prefix = 's3://drug-discovery-joe-raw-data-team4/results/features_nextflow_team4'

  // TODO: replace with concrete team paths under results/<source>/
  sample_feature_uri = null
  drug_feature_uri = null
  label_uri = null

  sample_id_col = 'sample_id'
  drug_id_col = 'canonical_drug_id'
  drug_fallback_col = 'inchikey'
  regression_label_col = 'ic50'
  binary_label_col = 'binary_label'

  missing_threshold = 0.7
  variance_threshold = 0.0
  leakage_cols = ''
  normalization_branch = 'both'
  binary_from_quantile = 0.3
}

process {
  errorStrategy = 'terminate'
  maxRetries = 1
  cpus = 4
  memory = '16 GB'
  time = '8h'
}

profiles {
  local {
    process.executor = 'local'
    docker.enabled = false
  }

  docker_local {
    process.executor = 'local'
    docker.enabled = true
    docker.runOptions = '-u \$(id -u):\$(id -g)'
  }

  awsbatch {
    process.executor = 'awsbatch'
    process.queue = 'REPLACE_WITH_BATCH_JOB_QUEUE'
    process.container = '666803869796.dkr.ecr.ap-northeast-2.amazonaws.com/skku-project/pre-4team:fe-latest'
    aws.region = params.aws_region
    workDir = "s3://drug-discovery-joe-raw-data-team4/results/features_nextflow_team4/work"

    // For large parquet runs, keep staged files and retries conservative.
    process.maxRetries = 1
  }
}
